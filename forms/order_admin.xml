<?xml version="1.0" encoding="utf-8"?>
<form>
	<fieldset name="shipping">
		<fields name="shipping">
			<field name="recipient" type="apiship_recipient"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_RECIPIENT"
				   onchange="window.RadicalMartShippingApiShipOrder().calculate()"
				   required="true"/>
			<field name="sender" type="apiship_sender"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_SENDER"
				   onchange="window.RadicalMartShippingApiShipOrder().calculate()"
				   required="true"/>
			<field name="delivery_type" type="list"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE"
				   default="1"
				   onchange="RadicalMartCheckout().reloadForm(this, 'shipping')">
				<option value="1">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_1</option>
				<option value="2">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_2</option>
			</field>
			<fields name="price">
				<field name="base" type="hidden" required="true" readonly="true"/>
				<field name="final" type="hidden"  readonly="true"/>
				<field name="hash" type="hidden" required="true"/>
			</fields>
		</fields>
	</fieldset>
</form>