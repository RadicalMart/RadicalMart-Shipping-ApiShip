<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field">
	<fieldset name="shipping">
		<fields name="shipping">
			<field name="point" type="ApiShip_Points"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_CHECKOUT_POINT"
				   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_POINT_HINT"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   onchange="window.RadicalMartShippingApiShipCheckout().loadTariffs();"
				   required="true"/>
			<field name="address" type="ApiShip_Addresses"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_CHECKOUT_ADDRESS"
				   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_ADDRESS_HINT"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   onchange="window.RadicalMartShippingApiShipCheckout().loadTariffs();"
				   required="true"/>
			<field name="tariff" type="ApiShip_Tariffs"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_CHECKOUT_TARIFF"
				   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_TARIFF_HINT"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   onchange="window.RadicalMartShippingApiShipCheckout().updateShippingPrice();"
				   required="true"/>
			<field name="comment" type="textarea"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_COMMENT"
				   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_COMMENT_HINT"/>
		</fields>
	</fieldset>
</form>