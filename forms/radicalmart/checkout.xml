<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field">
	<fieldset name="shipping">
		<fields name="shipping">
			<field name="sender" type="sender"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_SENDER"
				   onchange="window.RadicalMartShippingApiShipRadicalMart().calculate()"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   required="true"/>
			<field name="delivery_type" type="list"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE"
				   default="1"
				   onchange="RadicalMartCheckout().reloadForm(this, 'shipping.apiship')">
				<option value="1">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_1</option>
				<option value="2">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_2</option>
			</field>
			<field name="recipient" type="recipient"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_RECIPIENT"
				   onchange="window.RadicalMartShippingApiShipRadicalMart().calculate()"
				   hint="PLG_RADICALMART_SHIPPING_APISHIP_RECIPIENT_HINT"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   required="true"/>
			<field name="point" type="points"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_POINT"
				   onchange="window.RadicalMartShippingApiShipRadicalMart().calculate()"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
				   operation="[2,3]"
				   required="true"/>
			<fields name="price">
				<field name="base" type="hidden" required="true" readonly="true"/>
				<field name="final" type="hidden" readonly="true"/>
				<field name="hash" type="hidden" required="true"/>
			</fields>
		</fields>
	</fieldset>
</form>