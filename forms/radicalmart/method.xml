<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field">
	<fieldset name="settings_api" label="PLG_RADICALMART_SHIPPING_APISHIP_PARAMS_API">
		<fields name="params">
			<field name="sandbox" type="radio"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_PARAMS_SANDBOX"
				   class="btn-group btn-group-yesno"
				   default="0">
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>
			<field name="token" type="password"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_PARAMS_TOKEN"
				   showon="sandbox:0"/>
			<field name="provider" type="list"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER"
				   layout="joomla.form.field.list-fancy-select"
				   required="true">
				<option value="">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_SELECT</option>
				<option value="accordpost">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_ACCORDPOST</option>
				<option value="axilog">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_AXILOG</option>
				<option value="azexpress">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_AZEXPRESS</option>
				<option value="b2cpl">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_B2CPL</option>
				<option value="boxberry">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_BOXBERRY</option>
				<option value="cdek">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_CDEK</option>
				<option value="checkbox">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_CHECKBOX</option>
				<option value="cityex">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_CITYEX</option>
				<option value="cse">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_CSE</option>
				<option value="d-club">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_D-CLUB</option>
				<option value="dalli">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_DALLI</option>
				<option value="dellin">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_DELLIN</option>
				<option value="dostavista">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_DOSTAVISTA</option>
				<option value="dpd">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_DPD</option>
				<option value="drhl">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_DRHL</option>
				<option value="e-kit">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_E-KIT</option>
				<option value="easyway">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_EASYWAY</option>
				<option value="ebulky">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_EBULKY</option>
				<option value="gett">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_GETT</option>
				<option value="guru">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_GURU</option>
				<option value="hermes">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_HERMES</option>
				<option value="iml">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_IML</option>
				<option value="k-mestu">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_K-MESTU</option>
				<option value="logsis">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_LOGSIS</option>
				<option value="lpost">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_LPOST</option>
				<option value="marlinzet">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_MARLINZET</option>
				<option value="maxi">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_MAXI</option>
				<option value="neppost">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_NEPPOST</option>
				<option value="on-time">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_ON-TIME</option>
				<option value="ozon">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_OZON</option>
				<option value="pickpoint">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_PICKPOINT</option>
				<option value="pony">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_PONY</option>
				<option value="rudostavka">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_RUDOSTAVKA</option>
				<option value="rupost">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_RUPOST</option>
				<option value="sberlog">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_SBERLOG</option>
				<option value="smart">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_SMART</option>
				<option value="smartsend">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_SMARTSEND</option>
				<option value="td">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_TD</option>
				<option value="viehali">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_VIEHALI</option>
				<option value="vozovoz">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_VOZOVOZ</option>
				<option value="x5">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_X5</option>
				<option value="yataxi">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_YATAXI</option>
				<option value="zabberi">PLG_RADICALMART_SHIPPING_APISHIP_PROVIDER_ZABBERI</option>
			</field>
			<field name="delivery_type" type="list"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE"
				   default="0">
				<option value="0">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_0</option>
				<option value="1">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_1</option>
				<option value="2">PLG_RADICALMART_SHIPPING_APISHIP_DELIVERY_TYPE_2</option>
			</field>
		</fields>
	</fieldset>
	<fieldset name="settings_map" label="PLG_RADICALMART_SHIPPING_APISHIP_PARAMS_MAP">
		<fields name="params">
			<field name="map_key" type="text"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_PARAMS_MAP_KEY"
				   required="true"/>
		</fields>
	</fieldset>
	<fieldset name="settings_sender" label="PLG_RADICALMART_SHIPPING_APISHIP_SENDER" full_width="true">
		<fields name="params">
			<field name="sender" type="places"
				   label="PLG_RADICALMART_SHIPPING_APISHIP_SENDER"
				   hiddenLabel="true"
				   map_error="PLG_RADICALMART_SHIPPING_APISHIP_ERROR_SENDER_MAP_KEY"
				   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"/>
		</fields>
	</fieldset>
</form>