<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field">
	<fieldset>
		<field name="addresses" type="subform"
			   label="PLG_RADICALMART_SHIPPING_APISHIP_CUSTOMER_ADDRESSES"
			   multiple="true"
			   parentclass="stack"
			   buttons="add,remove"
			   min="1">
			<form>
				<field name="uid" type="hidden"/>
				<field name="provider" type="ApiShip_Providers"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_PROVIDER"
					   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"/>
				<field name="country" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_COUNTRY"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_COUNTRY_HINT"/>
				<field name="region" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_REGION"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_REGION_HINT"/>
				<field name="city" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_CITY"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_CITY_HINT"/>
				<field name="zip" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_ZIP"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_ZIP_HINT"/>
				<field name="street" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_STREET"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_STREET_HINT"/>
				<field name="house" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_HOUSE"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_HOUSE_HINT"/>
				<field name="building" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_BUILDING"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_BUILDING_HINT"/>
				<field name="entrance" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_ENTRANCE"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_ENTRANCE_HINT"/>
				<field name="floor" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_FLOOR"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_FLOOR_HINT"/>
				<field name="apartment" type="text"
					   label="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_APARTMENT"
					   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_APARTMENT_HINT"/>
			</form>
		</field>
		<field name="point" type="ApiShip_Points"
			   label="PLG_RADICALMART_SHIPPING_APISHIP_PERSONAL_POINT"
			   hint="PLG_RADICALMART_SHIPPING_APISHIP_FIELD_POINT_HINT"
			   addfieldprefix="Joomla\Plugin\RadicalMartShipping\ApiShip\Field"
			   parentclass="stack"/>
	</fieldset>
</form>